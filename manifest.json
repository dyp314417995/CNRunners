{
  "name": "九州战马联盟",
  "appid": "",
  "description": "九州战马联盟 CNRunners 跑团成员管理小程序",
  "versionName": "1.0.0",
  "versionCode": "100",
  "transformPx": false,
  "app-plus": {
    "usingComponents": true,
